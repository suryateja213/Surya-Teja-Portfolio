# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (any package)
**/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
**/coverage

# next.js (frontend/)
**/.next/
**/out/

# production
**/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ---- backend (FastAPI / Python) ----
**/__pycache__/
*.py[cod]
.venv/
**/.venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
# Lambda packaging artifacts
backend/build/
backend/*.zip

# ---- infra (Terraform) ----
**/.terraform/
*.tfstate
*.tfstate.*
crash.log
*.tfplan
# saved plan files may contain sensitive variable values
tfplan
**/tfplan
# keep the lock file committed:
!**/.terraform.lock.hcl
infra/terraform/modules/lambda_fastapi/placeholder.zip
