# Base URL of the FastAPI backend the contact form POSTs to.
# This value is baked into the static build at `next build` time, so changing
# it requires a frontend rebuild + redeploy (not just a config flip).
#
# Local dev:  http://localhost:8000
# Production: https://api.kommugurisuryateja.com
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
