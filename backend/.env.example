# Backend configuration. Copy to `.env` for local dev; in production these are
# set as Lambda environment variables by Terraform (secrets never committed).

# DynamoDB single-table name.
TABLE_NAME=surya-portfolio

# AWS region for the DynamoDB client.
AWS_REGION=us-east-1

# Local-only: point boto3 at DynamoDB Local / moto. Leave UNSET in production.
# DYNAMODB_ENDPOINT_URL=http://localhost:8001

# JWT signing. Generate a strong secret: `openssl rand -hex 32`.
JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=60

# Single admin credentials. Store only the bcrypt hash of the password.
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=

# CORS: comma-separated list of allowed frontend origins.
ALLOWED_ORIGINS=http://localhost:3000,https://kommugurisuryateja.com
